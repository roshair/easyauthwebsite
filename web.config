<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <staticContent>
      <!-- Cache static assets for 1 year -->
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />

      <!-- Set MIME types for modern formats -->
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <!-- Enable Gzip/Brotli compression -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- HTTP/2 push headers for critical resources -->
    <httpProtocol>
      <customHeaders>
        <add name="Link" value="&lt;/css/bootstrap.min.css&gt;; rel=preload; as=style" />
        <add name="Link" value="&lt;/js/bootstrap.min.js&gt;; rel=preload; as=script" />
        <add name="X-Content-Type-Options" value="nosniff" />
      </customHeaders>
    </httpProtocol>

    <!-- Rewrite rules for cache-busted (fingerprinted) asset filenames -->
    <rewrite>
      <rules>
        <rule name="Fingerprinted Assets">
          <match url="^(.*)\.([0-9]+)\.(css|js|jpg|png|gif|svg|woff|woff2)$" />
          <action type="Rewrite" url="{R:1}.{R:3}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
